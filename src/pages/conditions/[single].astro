---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Faq from "@/components/Faq.astro";
import JsonLd from "@/components/JsonLd.astro";
import PageHeader from "@/components/PageHeader.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import Cta from "@/partials/Cta.astro";

export async function getStaticPaths() {
  const conditions = await getSinglePage("conditions");
  return conditions.map((post: any) => ({
    params: { single: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, intro, symptoms, treatmentLinks, faqs } = post.data;

const base = (config.site.base_url || "").replace(/\/$/, "");
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description,
  url: `${base}/conditions/${post.slug}`,
  about: { "@type": "MedicalCondition", name: title },
  isPartOf: { "@type": "MedicalClinic", name: (config as any).business?.name },
};
---

<Base title={title} description={description}>
  <PageHeader title={title} />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Conditions", href: "/conditions" },
      { label: title },
    ]}
  />

  <section class="section pt-8">
    <div class="container">
      <div class="row justify-center">
        <div class="md:col-10 lg:col-8">
          {
            intro && (
              <div class="pb-8 text-[1.02rem] leading-relaxed sm:text-lg">
                {intro}
              </div>
            )
          }

          <div class="content">
            <Content />
          </div>

          {
            symptoms && symptoms.length > 0 && (
              <div class="mt-10 rounded-lg border border-border bg-theme-light/50 p-5 md:p-8">
                <h2 class="mb-4 text-h4-sm font-semibold md:text-h4">
                  Common symptoms
                </h2>
                <ul class="list-disc space-y-1 pl-5 text-[0.95rem] text-text">
                  {symptoms.map((s: string) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </div>
            )
          }

          {
            treatmentLinks && treatmentLinks.length > 0 && (
              <div class="mt-8">
                <h2 class="mb-4 text-h4-sm font-semibold md:text-h4">
                  Treatments we may consider
                </h2>
                <p class="mb-5 text-[0.9rem] text-text">
                  The right approach depends on your diagnosis, your history and
                  your goals. Options that may be relevant for this condition
                  include:
                </p>
                <div class="flex flex-wrap gap-3">
                  {treatmentLinks.map((t: any) => (
                    <a
                      href={t.href}
                      class="rounded-full border border-primary/30 bg-white px-4 py-2 text-[0.88rem] font-medium text-dark transition hover:border-primary hover:text-primary"
                    >
                      {t.name}
                    </a>
                  ))}
                </div>
                <p class="mt-5 text-[0.8rem] text-text">
                  Not every treatment suits every person. Suitability and the
                  supporting evidence are discussed with you at consultation.
                </p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <Faq faqs={faqs ?? []} />

  <JsonLd schema={pageSchema} />
  <Cta />
</Base>
