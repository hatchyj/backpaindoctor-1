---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import Faq from "@/components/Faq.astro";
import JsonLd from "@/components/JsonLd.astro";
import PageHeader from "@/components/PageHeader.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import Cta from "@/partials/Cta.astro";

export async function getStaticPaths() {
  const conditions = await getSinglePage("conditions");
  return conditions.map((post: any) => ({
    params: { single: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, intro, symptoms, faqs } = post.data;

const base = (config.site.base_url || "").replace(/\/$/, "");
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  name: title,
  description,
  url: `${base}/conditions/${post.slug}`,
  about: { "@type": "MedicalCondition", name: title },
  isPartOf: { "@type": "MedicalClinic", name: (config as any).business?.name },
};

const conditionSlug = post.slug;

const iconPaths: Record<string, string> = {
  core: "M12 3.5 20 8v8l-8 4.5L4 16V8l8-4.5Zm0 2.3L6 9.2v5.6l6 3.4 6-3.4V9.2l-6-3.4Zm0 5.1 4.7-2.7L12 5.5 7.3 8.2 12 10.9Zm0 2.1L6.8 10v4.1l5.2 3 5.2-3V10L12 13Z",
  wave: "M3 13c2.2-4.6 5.3-4.6 7.5 0s5.3 4.6 7.5 0c.6-1.3 1.5-2.2 2.7-2.7M3 17c2.2-4.6 5.3-4.6 7.5 0s5.3 4.6 7.5 0c.6-1.3 1.5-2.2 2.7-2.7M3 9c2.2-4.6 5.3-4.6 7.5 0s5.3 4.6 7.5 0c.6-1.3 1.5-2.2 2.7-2.7",
  platelet: "M12 21a7 7 0 0 0 7-7c0-4.5-5.2-9.4-6.6-10.7a.6.6 0 0 0-.8 0C10.2 4.6 5 9.5 5 14a7 7 0 0 0 7 7Zm-2.2-6.8h4.4M12 12v4.4",
  injection: "M14.5 4.5 19.5 9.5M12.3 6.7l5 5M5 19l5.5-5.5m0 0 5.6-5.6-2-2-5.6 5.6m2 2-2-2M4 20l1-1",
  field: "M12 4a8 8 0 1 0 8 8M12 7a5 5 0 1 0 5 5M12 10a2 2 0 1 0 2 2M17 3v6h6M17 9l5.5-5.5",
  stability: "M12 3 20 7v5c0 5-3.4 8.3-8 9-4.6-.7-8-4-8-9V7l8-4Zm-3 9 2 2 4-5",
  target: "M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Zm0-4.5a4.5 4.5 0 1 0-4.5-4.5 4.5 4.5 0 0 0 4.5 4.5Zm0-2.2a2.3 2.3 0 1 0-2.3-2.3 2.3 2.3 0 0 0 2.3 2.3Z",
  nerve: "M5 12c2.5 0 2.5-5 5-5s2.5 10 5 10 2.5-5 5-5M4 7h3M4 17h3M17 7h3M17 17h3",
};

const statusStyles: Record<string, string> = {
  foundation: "bg-primary text-white ring-primary/20",
  supported: "bg-[#E8F4EF] text-[#16633B] ring-[#BFE1CF]",
  limited: "bg-[#FFF7E6] text-[#8A5A00] ring-[#F5D58B]",
  unsupported: "bg-[#F7F7F8] text-[#5D6673] ring-border",
  notRoutine: "bg-[#FDECEC] text-[#8C2D2D] ring-[#F4CACA]",
};

const treatmentMenu = [
  {
    id: "rehab",
    name: "Diagnosis, education and progressive rehabilitation",
    href: null,
    icon: "core",
    defaultStatus: "foundation",
    defaultTag: "Foundation",
    defaultEvidence: "This is the starting point for most musculoskeletal conditions.",
    defaultSummary:
      "The priority is to identify the likely pain generator, explain the condition clearly, modify aggravating load and build a realistic plan to restore strength, movement and confidence.",
  },
  {
    id: "shockwave",
    name: "Focused / radial shockwave therapy",
    href: "/non-surgical-treatments/shockwave-therapy-eswt",
    icon: "wave",
    defaultStatus: "limited",
    defaultTag: "Condition-dependent",
    defaultEvidence: "Evidence is condition-specific; it is not a universal pain treatment.",
    defaultSummary:
      "Shockwave is best framed as an adjunct where the diagnosis fits. It is generally more established for selected tendon and plantar heel pain presentations than for many joint or nerve conditions.",
  },
  {
    id: "prp",
    name: "Platelet-rich plasma (PRP)",
    href: "/non-surgical-treatments/platelet-rich-plasma-treatment",
    icon: "platelet",
    defaultStatus: "limited",
    defaultTag: "Selected cases",
    defaultEvidence: "Evidence varies substantially by condition, tissue and preparation method.",
    defaultSummary:
      "PRP may be discussed in selected tendon or joint presentations. It should not be presented as a guaranteed regenerative treatment, and uncertainty, cost and alternatives should be discussed.",
  },
  {
    id: "injection",
    name: "Image-guided corticosteroid / local anaesthetic injection",
    href: "/patient-resources/cortisone-injections-benefits-and-limits",
    icon: "injection",
    defaultStatus: "limited",
    defaultTag: "Symptom relief",
    defaultEvidence: "Best used for specific inflammatory or irritable pain generators, usually for short-term relief.",
    defaultSummary:
      "An injection may help when a joint, bursa, tendon sheath or other defined structure is driving symptoms. It is not a cure and needs to be weighed against risks, recurrence and the need for rehabilitation.",
  },
  {
    id: "emtt",
    name: "EMTT / magnetotransduction",
    href: "/non-surgical-treatments/emtt-magnetotransduction",
    icon: "field",
    defaultStatus: "limited",
    defaultTag: "Emerging adjunct",
    defaultEvidence: "Clinical evidence is still developing and guideline support is limited.",
    defaultSummary:
      "EMTT may be discussed as an adjunct in selected presentations, but should be presented with clear uncertainty and never as a replacement for diagnosis, load management or rehabilitation.",
  },
  {
    id: "prolotherapy",
    name: "Prolotherapy",
    href: "/non-surgical-treatments/prolotherapy-treatment",
    icon: "stability",
    defaultStatus: "limited",
    defaultTag: "Selected cases",
    defaultEvidence: "Evidence is condition-specific and generally less established than exercise-based care.",
    defaultSummary:
      "Prolotherapy may be considered in carefully selected chronic ligament, tendon or joint-related pain presentations, but it is not a first-line treatment.",
  },
  {
    id: "triggerPoint",
    name: "Trigger point / myofascial treatment",
    href: "/non-surgical-treatments/trigger-point-therapy-treatment",
    icon: "target",
    defaultStatus: "limited",
    defaultTag: "Pain modulator",
    defaultEvidence: "Most relevant when focal myofascial pain is a clear contributor.",
    defaultSummary:
      "Trigger point treatment may reduce pain from focal muscle spasm or myofascial tenderness. It should be paired with movement restoration, strength work and recurrence prevention.",
  },
  {
    id: "nerve",
    name: "Nerve-focused treatment / hydrodissection",
    href: "/non-surgical-treatments/nerve-therapy-treatment",
    icon: "nerve",
    defaultStatus: "limited",
    defaultTag: "Nerve-specific",
    defaultEvidence: "Relevant only when the history and examination support nerve irritation or entrapment.",
    defaultSummary:
      "Nerve-focused treatment may be discussed when there is a plausible peripheral nerve pain generator. Progressive weakness, major neurological deficit or red flags require a different pathway.",
  },
];

const conditionEvidenceOverrides: Record<string, Record<string, any>> = {
  "knee-osteoarthritis": {
    rehab: {
      status: "supported",
      tag: "Core treatment",
      evidence: "Therapeutic exercise, education and weight management where relevant are core osteoarthritis treatments.",
      summary:
        "For knee osteoarthritis, the first-line plan is usually education, activity modification, strength work, aerobic conditioning and weight management where clinically relevant. Treatment is guided by symptoms and function, not imaging alone.",
    },
    shockwave: {
      status: "limited",
      tag: "Limited evidence",
      evidence: "AAOS states ESWT may improve pain and function in knee osteoarthritis, but the recommendation is limited and downgraded because of inconsistent evidence.",
      summary:
        "Focused shockwave can be discussed for selected knee osteoarthritis patients, particularly when the aim is symptom reduction and function support. It should not be positioned as cartilage regeneration, disease reversal or a replacement for exercise-based care.",
    },
    prp: {
      status: "limited",
      tag: "Mixed evidence",
      evidence: "PRP evidence in knee osteoarthritis is inconsistent; AAOS downgraded its PRP recommendation because of inconsistent evidence.",
      summary:
        "PRP may be discussed for selected patients after a careful conversation about uncertainty, cost, expected time course, severity of OA, alternatives and the fact that responses are variable.",
    },
    injection: {
      status: "supported",
      tag: "Short-term relief",
      evidence: "Guidelines support corticosteroid injections for short-term symptom relief in selected osteoarthritis presentations.",
      summary:
        "Corticosteroid injection may help during a painful flare or when pain is preventing rehabilitation. It should be framed as short-term symptom relief, not structural repair.",
    },
    emtt: {
      status: "limited",
      tag: "Insufficient guideline support",
      evidence: "Major osteoarthritis guidelines do not establish EMTT as a core knee osteoarthritis treatment.",
      summary:
        "EMTT may be discussed only as an adjunct with explicit uncertainty. It should not be presented as a proven disease-modifying treatment for knee osteoarthritis.",
    },
    prolotherapy: {
      status: "notRoutine",
      tag: "Not routine",
      evidence: "Not a core guideline-supported knee osteoarthritis treatment.",
      summary:
        "Prolotherapy is not usually a first-line knee osteoarthritis treatment. If discussed, it should be after clear diagnosis and careful explanation of limited evidence compared with core OA care.",
    },
    triggerPoint: {
      status: "unsupported",
      tag: "Only if overlay",
      evidence: "Trigger point therapy does not treat osteoarthritis itself.",
      summary:
        "It may be relevant only if there is a clear secondary myofascial pain component around the hip, thigh or calf. It should not be described as an OA treatment.",
    },
    nerve: {
      status: "unsupported",
      tag: "Usually not relevant",
      evidence: "Nerve hydrodissection is not a treatment for knee osteoarthritis.",
      summary:
        "Nerve-focused treatment would only be considered if the clinical picture suggests a separate nerve entrapment or neuropathic pain generator.",
    },
  },
};

const supportedShockwave = [
  "achilles-tendinopathy",
  "plantar-fasciitis",
  "greater-trochanteric-pain-syndrome",
  "shoulder-calcific-tendinopathy",
  "tennis-golfers-elbow",
];

const supportedInjection = [
  "frozen-shoulder",
  "shoulder-osteoarthritis",
  "thumb-base-osteoarthritis",
  "de-quervain-tenosynovitis",
  "carpal-tunnel-syndrome",
  "morton-neuroma",
  "greater-trochanteric-pain-syndrome",
  "shoulder-calcific-tendinopathy",
];

const nerveRelevant = [
  "carpal-tunnel-syndrome",
  "cervical-radiculopathy",
  "sciatica",
  "morton-neuroma",
];

const getTreatmentCard = (treatment: any) => {
  const override = conditionEvidenceOverrides[conditionSlug]?.[treatment.id];

  if (override) {
    return { ...treatment, ...override };
  }

  if (treatment.id === "rehab") {
    return { ...treatment, status: "foundation", tag: treatment.defaultTag, evidence: treatment.defaultEvidence, summary: treatment.defaultSummary };
  }

  if (treatment.id === "shockwave" && supportedShockwave.includes(conditionSlug)) {
    return {
      ...treatment,
      status: "supported",
      tag: "Often relevant",
      evidence: "Best supported when the diagnosis is a suitable tendinopathy or plantar heel pain presentation.",
      summary:
        "Shockwave may be clinically relevant when symptoms persist despite appropriate load management and rehabilitation. It remains an adjunct, not a substitute for progressive loading and diagnosis-specific care.",
    };
  }

  if (treatment.id === "injection" && supportedInjection.includes(conditionSlug)) {
    return {
      ...treatment,
      status: "supported",
      tag: "May be relevant",
      evidence: "May provide symptom relief when the pain generator is a joint, bursa, tendon sheath or other defined irritable structure.",
      summary:
        "Injection treatment may be discussed when pain is limiting sleep, function or rehabilitation. The expected benefit is usually symptom control, not tissue regeneration.",
    };
  }

  if (treatment.id === "nerve" && nerveRelevant.includes(conditionSlug)) {
    return {
      ...treatment,
      status: "limited",
      tag: "Only if nerve-driven",
      evidence: "Relevant only if symptoms, examination and imaging where appropriate support a nerve pain generator.",
      summary:
        "Nerve-focused treatment may be discussed when the clinical picture supports nerve irritation or entrapment. Progressive deficit or red flags require escalation.",
    };
  }

  return {
    ...treatment,
    status: treatment.defaultStatus,
    tag: treatment.defaultTag,
    evidence: treatment.defaultEvidence,
    summary: treatment.defaultSummary,
  };
};

const treatmentSummaryCards = treatmentMenu.map(getTreatmentCard);
---

<Base title={title} description={description}>
  <PageHeader title={title} />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Conditions", href: "/conditions" },
      { label: title },
    ]}
  />

  <section class="section pt-8">
    <div class="container">
      <div class="row justify-center">
        <div class="md:col-10 lg:col-8">
          {
            intro && (
              <div class="pb-8 text-[1.02rem] leading-relaxed sm:text-lg">
                {intro}
              </div>
            )
          }

          <div class="content">
            <Content />
          </div>

          {
            symptoms && symptoms.length > 0 && (
              <div class="mt-10 rounded-2xl border border-border bg-theme-light/50 p-5 md:p-8">
                <h2 class="mb-4 text-h4-sm font-semibold md:text-h4">
                  Common symptoms
                </h2>
                <ul class="list-disc space-y-1 pl-5 text-[0.95rem] text-text">
                  {symptoms.map((s: string) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </div>
            )
          }

          <section class="mt-10 overflow-hidden rounded-[1.75rem] border border-primary/10 bg-white shadow-[0_24px_70px_rgba(5,83,203,0.08)]">
            <div class="border-b border-border/70 bg-gradient-to-br from-[#F4F8FC] via-white to-[#EAF3FF] p-5 md:p-8">
              <div class="mb-3 inline-flex items-center rounded-full border border-primary/20 bg-white/80 px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-primary">
                Evidence-informed treatment summary
              </div>
              <h2 class="mb-3 text-h4-sm font-semibold leading-tight text-dark md:text-h4">
                How our treatment options may fit for {title}
              </h2>
              <p class="max-w-3xl text-[0.95rem] leading-relaxed text-text">
                The options below include the treatments offered at The Back Pain Doctor. Listing a treatment does not mean it is recommended for this condition. The evidence, likely benefit and role of each option are considered against the diagnosis, examination findings, imaging where appropriate, patient goals, risks, cost and alternatives.
              </p>
            </div>

            <div class="grid gap-4 p-5 md:grid-cols-2 md:p-8">
              {treatmentSummaryCards.map((card: any) => (
                <article class="group relative rounded-2xl border border-border/80 bg-white p-5 transition duration-200 hover:-translate-y-0.5 hover:border-primary/35 hover:shadow-[0_18px_45px_rgba(12,42,66,0.08)]">
                  <div class="mb-4 flex items-start gap-4">
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-primary/8 text-primary ring-1 ring-primary/10">
                      <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d={iconPaths[card.icon] ?? iconPaths.stability} />
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="mb-2 flex flex-wrap items-center gap-2">
                        <span class={`rounded-full px-2.5 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.08em] ring-1 ${statusStyles[card.status] ?? statusStyles.limited}`}>
                          {card.tag}
                        </span>
                      </div>
                      <h3 class="text-[1.02rem] font-semibold leading-snug text-dark">
                        {card.href ? (
                          <a href={card.href} class="transition hover:text-primary">
                            {card.name}
                          </a>
                        ) : (
                          card.name
                        )}
                      </h3>
                    </div>
                  </div>

                  <p class="mb-3 text-[0.88rem] font-medium leading-relaxed text-dark">
                    {card.evidence}
                  </p>
                  <p class="text-[0.87rem] leading-relaxed text-text">
                    {card.summary}
                  </p>

                  {card.href && (
                    <a href={card.href} class="mt-4 inline-flex items-center gap-2 text-[0.84rem] font-semibold text-primary">
                      Read more
                      <span aria-hidden="true">→</span>
                    </a>
                  )}
                </article>
              ))}
            </div>

            <div class="border-t border-border/70 bg-theme-light/45 px-5 py-4 md:px-8">
              <p class="text-[0.78rem] leading-relaxed text-text">
                This is general information only. Suitability is assessed individually. Treatments with limited or condition-dependent evidence may still be discussed, but only with clear explanation of uncertainty, expected benefit, risks, cost and alternatives. Red flags, progressive neurological symptoms or suspected serious pathology require a different pathway.
              </p>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <Faq faqs={faqs ?? []} />

  <JsonLd schema={pageSchema} />
  <Cta />
</Base>
