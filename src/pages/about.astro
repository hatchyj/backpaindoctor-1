---
import AboutIntro from "@/components/about/AboutIntro.astro";
import AboutService from "@/components/about/AboutService.astro";
import AboutShortVideo from "@/components/about/AboutShortVideo.astro";
import Clients from "@/components/about/Clients.astro";
import PageHeader from "@/components/PageHeader.astro";
import Base from "@/layouts/Base.astro";
import Cta from "@/partials/Cta.astro";
import { getEntry } from "astro:content";

const about = await getEntry("about", "index");
const { title } = about.data;
const { data } = about;
const {
  about_us,
  description,
  works,
  mission,
  intro,
  clients
} = data;
---

<Base title={title} description={description}>
  <PageHeader title={title} />
  <!-- about us -->
  <AboutIntro data={about_us} order="left" />
  <!-- about service -->
  <AboutService works={works} />
  <!-- our mission -->
  <AboutIntro data={mission} order="right" />
  <!-- short video section -->
  <AboutShortVideo video={intro} />

  <!-- our clients -->
  <Clients clients={clients} />
  <!-- call to action -->
  <Cta />
</Base>
