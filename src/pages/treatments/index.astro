---
import IntroSection from "@/components/IntroSection.astro";
import PageHeader from "@/components/PageHeader.astro";
import Service from "@/components/Service.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import Cta from "@/partials/Cta.astro";
import { getEntry } from "astro:content";

const treatments = await getSinglePage("treatments");
const treatments_index = await getEntry("treatments", "-index");
const { title, description, intro, service } = treatments_index?.data;

---

<Base title={title} description={description}>
  <PageHeader title={title} />
  <IntroSection intro={intro} />
  
  <Service service={service} />
  <Cta />
</Base>
