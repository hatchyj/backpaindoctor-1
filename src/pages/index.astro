---
import Banner from "@/components/Banner.astro";
import CredentialStrip from "@/components/CredentialStrip.astro";
import Service from "@/components/Service.astro";
import Base from "@/layouts/Base.astro";
import Cta from "@/partials/Cta.astro";
import { getEntry } from "astro:content";

const homepage = await getEntry("homepage", "index");
const { banner, service } = homepage.data;
---

<Base
  title="Back Pain & Musculoskeletal Medicine — Dr Joshua Hatch"
  description="Brisbane musculoskeletal GP Dr Joshua Hatch provides evidence-based, non-surgical care for back pain, tendinopathy and joint pain — including PRP (platelet rich plasma) and focused shockwave therapy in Milton, Brisbane."
>
  <Banner banner={banner} />
  <CredentialStrip />
  <Service service={service} />
  <Cta />
</Base>
