              </div>
            </div>
            <div class="lg:col-5">
              <Image
                src="/images/CTA_Book_Appointment.png"
                height={511}
                width={494}
                class="max-w-full"
                alt="Book an Appointment today"
              />
            </div>
          </div>
          <div class="has-circle has-bg-animate h-full" data-aos="fade-in">
            <Circle classes={"top-[19%] left-[8%] ratio-32"} />
            <Circle classes={"top-[15%] left-[29%] ratio-20"} />
            <Circle classes={"bottom-[20%] left-[35%] ratio-20"} />
