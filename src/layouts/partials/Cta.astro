---
import config from "@/config/config.json";
import Circle from "@/layouts/components/Circle.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

const {
  title,
  content,
  button: { label, link },
  enable,
} = config.call_to_action;
