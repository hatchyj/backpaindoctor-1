---
import TwSizeIndicator from "@/components/TwSizeIndicator.astro";
import config from "@/config/config.json";
import theme from "@/config/theme.json";
import { plainify } from "@/lib/utils/textConverter";
import Footer from "@/partials/Footer.astro";
import Header from "@/partials/Header.astro";
import JsonLd from "@/components/JsonLd.astro";
import "@/styles/style.scss";
import { AstroFont } from "astro-font";

// font families
const pf = theme.fonts.font_family.primary;
const sf = theme.fonts.font_family.secondary;

let fontPrimary, fontSecondary;
if (theme.fonts.font_family.primary) {
  fontPrimary = theme.fonts.font_family.primary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;]+/gi, "");
}
if (theme.fonts.font_family.secondary) {
  fontSecondary = theme.fonts.font_family.secondary
    .replace(/\+/g, " ")
    .replace(/:[ital,]*[ital@]*[wght@]*[0-9,;]+/gi, "");
}

// types for frontmatters
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  landingPage?: boolean;
}

// distructure frontmatters
const {
  title,
  meta_title,
  description,
  image,
  noindex,
  canonical,
  landingPage,
} = Astro.props;

const siteBaseUrl = config.site.base_url.endsWith("/")
  ? config.site.base_url
  : `${config.site.base_url}/`;
const pageTitle = plainify(
  meta_title
    ? `${meta_title} | ${config.site.title}`
    : title
      ? `${title} | ${config.site.title}`
      : config.site.title,
);
const pageDescription = plainify(
  description ? description : config.metadata.meta_description,
);
const canonicalUrl =
  canonical || new URL(Astro.url.pathname, siteBaseUrl).toString();
const imagePath = image ? image : config.metadata.meta_image;
const socialImageUrl = new URL(imagePath, siteBaseUrl).toString();

// Site-wide organisation / practitioner schema (local SEO + E-E-A-T)
const biz = (config as any).business;
const orgSchema = biz
  ? {
      "@context": "https://schema.org",
      "@type": ["MedicalClinic", "Physician"],
      "@id": new URL("#clinic", siteBaseUrl).toString(),
      name: biz.name,
      description: biz.description,
      url: biz.url,
      telephone: biz.phone,
      image: socialImageUrl,
      logo: new URL(config.site.logo, siteBaseUrl).toString(),
      medicalSpecialty: "PhysicalMedicine",
      address: {
        "@type": "PostalAddress",
        streetAddress: biz.street,
        addressLocality: biz.suburb,
        addressRegion: biz.state,
        postalCode: biz.postcode,
        addressCountry: biz.country,
      },
      areaServed: "Brisbane, Queensland",
      founder: {
        "@type": "Physician",
        name: "Dr Joshua Hatch",
        image: new URL(
          "/images/dr-joshua-hatch-headshot-2026.webp",
          siteBaseUrl,
        ).toString(),
        medicalSpecialty: "Musculoskeletal Medicine",
      },
      sameAs: [
        "https://www.facebook.com/thebackpaindoctorau/",
        "https://www.instagram.com/back_pain_doctor/",
      ],
    }
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6D80YGJVPP"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-6D80YGJVPP');
    </script>

    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="andromeda-astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

    <!-- google font css -->
    <AstroFont
      config={[
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontPrimary!,
          fallback: "sans-serif",
          cssVariable: "font-primary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${pf}&display=swap`,
        },
        {
          src: [],
          preload: false,
          display: "swap",
          name: fontSecondary!,
          fallback: "sans-serif",
          cssVariable: "font-secondary",
          googleFontsURL: `https://fonts.googleapis.com/css2?family=${sf}&display=swap`,
        },
      ]}
    />

    <!-- aos style link -->
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <!-- swiper link -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css"
    />
    <!-- responsive meta -->
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />

    <!-- title -->
    <title>{pageTitle}</title>
    
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- canonical url -->
    <link rel="canonical" href={canonicalUrl} item-prop="url" />

    <!-- noindex robots -->
    {
      noindex ? (
        <meta name="robots" content="noindex,nofollow" />
      ) : (
        <meta name="robots" content="index,follow,max-image-preview:large" />
      )
    }

    <!-- meta-description -->
    <meta name="description" content={pageDescription} />

    <!-- author from config.json -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og-title -->
    <meta property="og:title" content={pageTitle} />

    <!-- og-description -->
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={config.site.title} />
    <meta property="og:locale" content="en_AU" />

    <!-- twitter-title -->
    <meta name="twitter:title" content={pageTitle} />

    <!-- twitter-description -->
    <meta name="twitter:description" content={pageDescription} />

    <!-- og-image -->
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Dr Joshua Hatch at The Back Pain Doctor Brisbane"
    />

    <!-- twitter-image -->
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- organisation / practitioner structured data -->
    <JsonLd schema={orgSchema} />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="site-ambient" aria-hidden="true"></div>
    <TwSizeIndicator />
    {!landingPage && <Header />}
    <main id="main-content">
      <slot />
    </main>
    {!landingPage && <Footer />}
    <script is:inline src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <!-- rellax script -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/gh/dixonandmoe/rellax@master/rellax.min.js"
    ></script>
    <script is:inline>
      if (window.AOS) {
        AOS.init({
          duration: 720,
          easing: "ease-out-cubic",
          once: true,
          offset: 70,
        });
      }

      if (window.Rellax) {
        new Rellax(".rellax");
      }

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const root = document.documentElement;
      const setScrollProgress = () => {
        const scrollable = document.body.scrollHeight - window.innerHeight;
        const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
        root.style.setProperty("--scroll-progress", progress.toFixed(4));
      };

      setScrollProgress();
      window.addEventListener("scroll", setScrollProgress, { passive: true });
      window.addEventListener("resize", setScrollProgress);

      if (!prefersReducedMotion) {
        document.querySelectorAll(".hero-media").forEach((media) => {
          media.addEventListener("pointermove", (event) => {
            const rect = media.getBoundingClientRect();
            const x = (event.clientX - rect.left) / rect.width - 0.5;
            const y = (event.clientY - rect.top) / rect.height - 0.5;

            media.style.setProperty("--tilt-x", `${(-y * 4).toFixed(2)}deg`);
            media.style.setProperty("--tilt-y", `${(x * 5).toFixed(2)}deg`);
            media.style.setProperty("--shine-x", `${(x * 70 + 50).toFixed(1)}%`);
            media.style.setProperty("--shine-y", `${(y * 70 + 50).toFixed(1)}%`);
          });

          media.addEventListener("pointerleave", () => {
            media.style.removeProperty("--tilt-x");
            media.style.removeProperty("--tilt-y");
            media.style.removeProperty("--shine-x");
            media.style.removeProperty("--shine-y");
          });
        });

        const premiumTargets = document.querySelectorAll(
          ".service-row, .cta-panel, .credential-panel, .service-visual, .about-visual, .btn",
        );

        premiumTargets.forEach((target) => {
          target.classList.add("premium-surface");
          target.addEventListener("pointermove", (event) => {
            const rect = target.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * 100;
            const y = ((event.clientY - rect.top) / rect.height) * 100;
            target.style.setProperty("--surface-x", `${x.toFixed(1)}%`);
            target.style.setProperty("--surface-y", `${y.toFixed(1)}%`);
          });
        });
      }
    </script>
  </body>
</html>
