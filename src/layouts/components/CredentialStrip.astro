---
import config from "@/config/config.json";

const cred = (config as any).credentials;
const enable = cred?.enable;
const intro = cred?.intro;
const items = cred?.items ?? [];
const secondary = cred?.secondary_cta;
---

{
  enable && (
    <section class="py-8" aria-label="Practitioner credentials">
      <div class="container">
        <div
          class="rounded-2xl border border-primary/15 bg-theme-light/60 px-6 py-6 md:px-8"
          data-aos="fade-up"
        >
          {intro && (
            <p class="mb-4 text-center text-[0.8rem] font-medium uppercase tracking-wide text-text md:text-left">
              {intro}
            </p>
          )}
          <div class="row items-center justify-between gap-y-4">
            <div class="lg:col-9">
              <ul class="flex flex-wrap justify-center gap-x-6 gap-y-3 lg:justify-start">
                {items.map((item: any) => (
                  <li class="flex flex-col">
                    <span class="text-[0.95rem] font-semibold text-dark">
                      {item.label}
                    </span>
                    <span class="text-[0.78rem] text-text">{item.detail}</span>
                  </li>
                ))}
              </ul>
            </div>
            {secondary?.label && (
              <div class="lg:col-3 text-center lg:text-right">
                <a
                  href={secondary.link}
                  class="btn btn-outline-primary text-[0.85rem]"
                >
                  {secondary.label}
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}
