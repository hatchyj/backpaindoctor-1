---
import { markdownify } from "@/lib/utils/textConverter";
const { banner } = Astro.props;
const { title, meta, link, image } = banner;
---

<section class="hero-section">
  <div class="container relative">
    <div class="row min-h-[78vh] items-center gap-y-10 py-16 lg:py-20">
      <div class="lg:col-6" data-aos="fade-up">
        <p class="eyebrow">Brisbane musculoskeletal medicine</p>
        <h1
          set:html={markdownify(title)}
          class="mb-6 text-h2-sm font-semibold leading-tight md:text-h2-md lg:text-h1-md"
        />
        {
          meta && (
            <p
              set:html={markdownify(meta)}
              class="max-w-2xl text-lg leading-relaxed text-text"
            />
          )
        }
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={link.href} class="btn btn-primary">
            {link.label}
          </a>
          <a href="/about" class="btn btn-outline-primary">
            Meet Dr Joshua Hatch
          </a>
        </div>
      </div>
      <div class="lg:col-6" data-aos="fade-up" data-aos-delay="150">
        <figure class="hero-media">
          <img
            src={image}
            width="1400"
            height="1050"
            alt="Dr Joshua Hatch in navy scrubs at The Back Pain Doctor Brisbane"
            class="h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </div>
</section>
