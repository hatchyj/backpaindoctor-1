---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import readingTime from "@/lib/utils/readingTime";
import { plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";

const { blog } = Astro.props;
const { summary_length } = config.settings;

const {
  data: { title, image, author, authorImage, date },
  slug,
  body,
} = blog;
---

<article
  class="resource-card mt-6 overflow-hidden rounded-lg border border-primary/10 bg-white/90 shadow-sm"
>
  <a href={`/patient-resources/${slug}`}>
    <Image
      src={image}
      alt={title}
      class="aspect-[16/10] h-auto w-full bg-theme-light object-contain object-center"
      width={570}
      height={335}
    /></a
  >
  <div class="px-5 pb-2 pt-5 sm:px-[1.875rem] sm:pt-[2.1rem]">
    <h3
      class="card-title mb-2 text-[1.32rem] font-semibold leading-tight hover:underline sm:text-h4"
    >
      <a href={`/patient-resources/${slug}`}>{title}</a>
    </h3>
    <p class="mb-4 text-[0.95rem] leading-relaxed text-text">
      {plainify(body?.slice(0, Number(summary_length)))}...
    </p>
  </div>
  <div
    class="card-footer border-t-0 bg-transparent px-5 pb-5 sm:px-[1.875rem] sm:pb-[2.1rem]"
  >
    <div class="card-author">
      <div class="flex items-center">
        <div class="user-image mr-4">
          <a href={`/authors/${slugify(author)}`}>
            <Image
              src={authorImage}
              alt={author}
              class="max-w-full rounded-full"
              width={70}
              height={70}
            />
          </a>
        </div>
        <div class="user-info">
          <p class="mb-0 font-medium">
            <a href={`/authors/${slugify(author)}`}>{author}</a>
          </p>
          <span>{dateFormat(date)} - {readingTime(body)}</span>
        </div>
      </div>
    </div>
  </div>
</article>
