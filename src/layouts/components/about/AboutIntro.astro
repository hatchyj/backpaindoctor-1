---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
const {
  data: { title, subtitle, image, description },
  order,
} = Astro.props;
---

<section class="section">
  <div class="container relative">
    <div class="row items-center justify-center">
      <div
        class={`col-12 md:col-6 lg:col-4 ${
          order === "right" ? "order-1" : "order-1 md:order-0"
        }`}
      >
        <div class="section-title text-left">
          <p
            set:html={markdownify(subtitle)}
            class="mb-4 text-[0.9rem] uppercase"
          />
          <h2 set:html={markdownify(title)} class="service-title" />
          <p
            set:html={markdownify(description)}
            class="text-[.9rem] text-text"
          />
        </div>
      </div>
      <div
        class={`col-12 md:col-6 lg:col-5 ${
          order === "right" ? "order-0" : "order-0 md:order-1"
        }`}
      >
        <div class="about-visual">
          <div class="relative z-10">
            <Image
              src={image}
              height={436}
              width={381}
              alt={title}
              class="w-full max-w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
