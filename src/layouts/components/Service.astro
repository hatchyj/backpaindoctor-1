---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
const { service } = Astro.props;
---

<section class="section">
  <div class="container">
    {
      service.map((el: any, i: number) => (
        <div class="service-row row mb-10 items-center justify-center gap-y-8">
          <div
            class={`lg:col-5 ${i % 2 !== 0 ? "md:order-1" : "md:order-0"}`}
            data-aos="fade-up"
          >
            <div class="service-copy mb-0">
              <div class="section-title text-left">
                <p
                  set:html={markdownify(el.subtitle)}
                  class="eyebrow mb-4"
                />
                <h2 set:html={markdownify(el.title)} class="service-title" />
                <p
                  set:html={markdownify(el.description)}
                  class="text-[.9rem] text-text"
                />
                {el.hasCTA ? (
                  <a
                    href={el.cta.href}
                    class="mt-4 btn btn-outline-primary"
                    data-aos="fade"
                    data-aos-delay="50"
                  >
                    {el.cta.label}
                  </a>
                ) : (
                  <span></span>
                )}
              </div>
            </div>
          </div>
          <div
            class={`mt-4 lg:col-6 lg:mt-0 ${
              i % 2 !== 0 ? "md:order-0" : "md:order-1"
            }`}
            data-aos="fade-up"
            data-aos-delay="100"
          >
            <div class="service-visual pl-0 lg:pl-4">
              <Image
                src={el.image}
                height={511}
                width={575}
                class={`w-full max-w-full object-cover ${ 
                  el.image_style ? el.image_style : "" }`}
                alt={"Photo of " + el.title}
              />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
